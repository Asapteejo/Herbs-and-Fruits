{
    "name": "herbs and fruits",
    "version": "1.0.0",
    "description": "Herbs and Fruits Nigeria public site with Firebase Hosting and Functions",
    "main": "server.js",
    "scripts": {
        "build": "webpack --mode production",
        "watch": "webpack --mode development --watch",
        "start": "node server.js",
        "serve:local": "node server.js",
        "install:functions": "npm --prefix functions install",
        "deploy": "npm run build && firebase deploy",
        "deploy:hosting": "npm run build && firebase deploy --only hosting",
        "deploy:functions": "firebase deploy --only functions"
    },
    "dependencies": {
        "@babel/preset-env": "^7.26.9",
        "@babel/preset-react": "^7.26.3",
        "babel-loader": "^10.0.0",
        "body-parser": "^1.20.2",
        "css-loader": "^7.1.2",
        "express": "^4.18.2",
        "framer-motion": "^6.5.1",
        "gsap": "^3.12.7",
        "nodemailer": "^6.9.13",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "react-helmet": "^6.1.0",
        "react-image-lightbox": "^5.1.4",
        "react-lazy-load": "^4.0.1",
        "react-lazyload": "^3.2.1",
        "react-spinners": "^0.16.1",
        "style-loader": "^4.0.0",
        "webpack": "^5.99.6",
        "webpack-cli": "^6.0.1"
    }
}
